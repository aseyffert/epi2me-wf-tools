#!/usr/bin/env bash
#
# Sets up the user's environment to run EPI2ME workflows on the CHPC.
#
# To perform said setup, source this script; i.e., issue this command:
#   source /absolute/path/to/bash.env
# To have it performed at login, add said command to your $HOME/.bashrc file
#   (at your own risk; typically to the end of it).
#
# The NXF_{HOME,WORK,SINGULARITY_CACHEDIR} environments variables are the only
#   environment variables that will be respected if they already exist when this
#   script is sourced; all others (that this script exports) will be clobbered;
#   i.e., these are the only variables (that this script exports) that the user
#   has direct control over. (To specify your own values for these, export them
#   before sourcing this script.)

if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
  echo >&2 "ERROR: $0 not sourced."
  exit 1
fi

# NOTE:   The fallbacks for NXF_{WORK,SING*} are on lustre to protect $HOME from
#           heavy I/O loads.
# NB:     This fallback for NXF_WORK should not be treated as a default!
#           None of the tools that this package provides are designed to use
#           a monolithic NXF_WORK directory like this.
declare -A _nxf_fallbacks=(
  [NXF_HOME]=$HOME/nextflow_home
  [NXF_WORK]=/mnt/lustre/users/$USER/nextflow_work
  [NXF_SINGULARITY_CACHEDIR]=/mnt/lustre/users/$USER/singularity_cache
)
for _nxf_dir in "${!_nxf_fallbacks[@]}"; do
  [[ -v $_nxf_dir ]] || export "$_nxf_dir"="${_nxf_fallbacks[$_nxf_dir]}"
done
for _nxf_dir in NXF_{WORK,SINGULARITY_CACHEDIR}; do
  if [[ $_nxf_dir =~ $HOME/* ]]; then
    echo >&2 "WARN: To avoid unwanted I/O load on $(dirname "$HOME"), $_nxf_dir \
      should be located on /mnt/lustre/users/${USER}. \
      (Current location: ${!_nxf_dir}.)"
  fi
done
unset _nxf_fallbacks _nxf_dir

_hostname=$(hostname)

### Shared environment --- loaded both on compute and non-compute nodes
if _pth=$(realpath "${BASH_SOURCE[0]}") && EWT_HOME=$(dirname "$_pth"); then
  export EWT_HOME
  [[ $PATH =~ $EWT_HOME/tools ]] || export PATH=$EWT_HOME/tools:$PATH
else
  echo >&2 "ERROR: Could not derive EWT_HOME."
  return 1
fi
unset _pth

# FIXME:  This should be a function definition that uses a script in
#           $EWT_HOME/tools to resolve the research programme string.
# NOTE:   Users who belong to multiple groups must pass the desired
#           RESEARCH_PROGRAMME string for a head job-style run via the -v option
#           to qsub (or the corresponding #PBS line in the job script).
source "$EWT_HOME"/src/research_programme_handling.bash
[[ -v RESEARCH_PROGRAMME ]] || set_research_programme -p -q

# FIXME:  This should not be set to false for interactive runs; i.e., when the
#           user starts an interactive PBS job and runs nextflow themselves.
export NXF_ANSI_LOG='false'

# This is actually just a call to `module use` that prepends the appropriate
#   directory (which houses the nextflow module, among others) to MODULEPATH.
module load chpc/BIOMODULES

module load nextflow 2>/dev/null
[[ $_hostname != 'globus' ]] && module load chpc/singularity 2>/dev/null

### Compute node-only
if [[ $_hostname =~ cnode[0-9]+ ]]; then
  export NXF_OFFLINE='true'
  unset _hostname
  return
fi

### Other nodes
export NXF_DISABLE_CHECK_LATEST='true'

# Run `less` with ANSI colors support (used in nextflow log files) by default.
# alias less="less -R"

# Displays TSV files with spurious spaces correctly in less (e.g., trace.txt).
tless() {
  (($# > 0))
  local got_args=$?
  [[ ! -t 0 ]]
  local piped_to=$?
  if ((got_args && piped_to)); then
    echo >&2 "ERROR: Got filename(s) while processing piped input."
    return 1
  fi
  ((got_args || piped_to)) && column -ts $'\t', "$@" | less -S
}

# Prevents $HOME from leaking into nextflow's singularity auto mounts via $PWD.
alias cd="cd -P"

if [[ $_hostname == 'globus' ]]; then
  export APPTAINER_DISABLE_CACHE='true'
else
  export SINGULARITY_DISABLE_CACHE='true'
fi
unset _hostname
