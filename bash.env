#!/usr/bin/env bash
#
# Sets up the user's environment to run EPI2ME workflows on the CHPC.
#
# To have this setup done at login, add these three lines to your .bashrc:
#   export USER_LUSTRE=/mnt/lustre/users/$USER
#   export EWT_HOME=$USER_LUSTRE/epi2me-wf-tools
#   source $EWT_HOME/bash.env
# (Adapt line two accordingly if epi2me-wf-tools is located elsewhere.)

source $EWT_HOME/src/research_programme_handling.bash

[[ -v USER_LUSTRE ]] || export USER_LUSTRE=/mnt/lustre/users/$USER
set_research_programme -p -q

### Singularity
if [[ $(hostname) == 'globus' ]]; then
	export APPTAINER_DISABLE_CACHE=true
else
	export SINGULARITY_DISABLE_CACHE=true
fi

### Nextflow
export NXF_OFFLINE=true
export NXF_HOME=$USER_LUSTRE/nextflow_home
export NXF_SINGULARITY_CACHEDIR=$USER_LUSTRE/singularity_cache

# Run `less` with ANSI colors support (used in nextflow log files) by default.
alias less="less -R"

# Prevents $HOME from leaking into nextflow's singularity auto mounts via $PWD.
alias cd="cd -P"
