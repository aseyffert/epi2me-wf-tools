# Sets up the user's environment to run the epi2me-labs/wf-human-variation
#  workflow on the CHPC.
#
# To have this setup done at login, add these three lines to your .bashrc:
#   export USER_LUSTRE=/mnt/lustre/users/$USER
#   export EWT_HOME=$USER_LUSTRE/epi2me-wf-tools
#   source $EWT_HOME/bash.env
# (Adapt line two accordingly if epi2me-wf-tools is located elsewhere.)

not_sourced () { [[ "${FUNCNAME[-1]}" != 'source' ]]; }
if not_sourced; then
	echo >&2 'ERROR: script must be sourced.'
	exit 1
fi

[[ -v USER_LUSTRE ]] || export USER_LUSTRE=/mnt/lustre/users/$USER
read -r _ RESEARCH_PROGRAMME < <(id -Gn)
if (( $(wc -w <<< "$RESEARCH_PROGRAMME") == 1 )); then
	export RESEARCH_PROGRAMME
	GROUP_LUSTRE=/mnt/lustre/groups/$RESEARCH_PROGRAMME
	[[ -d $GROUP_LUSTRE ]] && export GROUP_LUSTRE || unset GROUP_LUSTRE
else
	echo >&2 'Warning: Unable to resolve RESEARCH_PROGRAMME group; not set.'
	unset RESEARCH_PROGRAMME
fi

### Singularity
if [[ $(hostname) == 'globus' ]]; then
	export APPTAINER_DISABLE_CACHE=true
else
	export SINGULARITY_DISABLE_CACHE=true
fi

### Nextflow
export NXF_OFFLINE=true
export NXF_HOME=$USER_LUSTRE/nextflow_home
export NXF_SINGULARITY_CACHEDIR=$USER_LUSTRE/singularity_cache
if [[ -v GROUP_LUSTRE ]]; then
	NXF_SINGULARITY_LIBRARYDIR=$GROUP_LUSTRE/singularity_images
	if [[ -d $NXF_SINGULARITY_LIBRARYDIR ]]; then
		export NXF_SINGULARITY_LIBRARYDIR
	else
		echo >&2 'Warning: NXF_SINGULARITY_LIBRARYDIR missing; not set.'
		unset NXF_SINGULARITY_LIBRARYDIR
	fi
fi

# Run `less` with ANSI colors support (used in nextflow log files) by default.
alias less="less -R"

# Prevents $HOME from leaking into nextflow's singularity auto mounts via $PWD.
alias cd="cd -P"
