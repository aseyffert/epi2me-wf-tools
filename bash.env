#!/usr/bin/env bash
#
# Sets up the user's environment to run EPI2ME workflows on the CHPC.
#
# To have this setup done at login, add these two lines to your .bashrc:
#   export EWT_HOME=/mnt/lustre/users/$USER/epi2me-wf-tools
#   source $EWT_HOME/bash.env
# (Adapt line one accordingly if epi2me-wf-tools is located elsewhere.)

[[ "$BASH_SOURCE" == "$0" ]] && { echo >&2 "ERROR: $0 not sourced."; exit 1; }

### Shared environment --- loaded both on compute and non-compute nodes
[[ -v USER_LUSTRE ]] || export USER_LUSTRE=/mnt/lustre/users/$USER
[[ -v EWT_HOME ]] || export EWT_HOME=$(dirname $(realpath $BASH_SOURCE))
export PATH=$EWT_HOME/tools:$PATH

# FIXME: This should be a function definition that uses a script in
#         $EWT_HOME/tools to resolve the research programme string.
# NOTE: Users who belong to multiple groups must pass the desired
#         RESEARCH_PROGRAMME string for a head job-style run via the -v option
#         to qsub (or the corresponding #PBS line in the job script).
source $EWT_HOME/src/research_programme_handling.bash
[[ -v RESEARCH_PROGRAMME ]] || set_research_programme -p -q

export NXF_HOME=$USER_LUSTRE/nextflow_home
export NXF_SINGULARITY_CACHEDIR=$USER_LUSTRE/singularity_cache
# FIXME: This should not be set to false for interactive runs; i.e., when the
#         user starts an interactive PBS job and runs nextflow themselves.
export NXF_ANSI_LOG='false'

### Compute node-only environment
if [[ $(hostname) =~ cnode[0-9]+ ]]; then
  export NXF_OFFLINE='true'
  module load chpc/singularity
  return
fi

### Non-compute node environment
module load chpc/BIOMODULES nextflow 2>/dev/null
NXF_DISABLE_CHECK_LATEST='true'

# Run `less` with ANSI colors support (used in nextflow log files) by default.
# alias less="less -R"

# Displays TSV files with spurious spaces correctly in less (e.g., trace.txt).
tless () { column -ts $'\t' "$1" | less -S; }

# Prevents $HOME from leaking into nextflow's singularity auto mounts via $PWD.
alias cd="cd -P"

if [[ $(hostname) == 'globus' ]]; then
  export APPTAINER_DISABLE_CACHE='true'
  return
fi

module load chpc/singularity
export SINGULARITY_DISABLE_CACHE='true'
